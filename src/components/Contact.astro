---
import Icon from './Icon.astro';

const socials = [
  { icon: 'facebook', label: 'Facebook', url: 'https://www.facebook.com/lakmalwijethungaa' },
  { icon: 'linkedin', label: 'LinkedIn', url: 'https://www.linkedin.com/in/lakmalwije/' },
  { icon: 'x-twitter', label: 'X (Twitter)', url: 'https://x.com/lakmal_wijeth' },
  { icon: 'instagram', label: 'Instagram', url: 'https://www.instagram.com/lakmal_wije/' },
  { icon: 'github', label: 'GitHub', url: 'https://github.com/lakmal-wijethunga' },
];
---

<section class="contact" id="contact">
  <div class="container">
    <div class="section-title">
      <h2>Get In Touch</h2>
    </div>
    <div class="contact-content reveal">
      <div class="contact-info">
        <h3>Let's Connect</h3>
        <div class="contact-details">
          <div class="contact-item">
            <div class="contact-icon"><Icon name="location-dot" /></div>
            <div>
              <h4>Location</h4>
              <p>Mirigama, Western Province</p>
            </div>
          </div>
          <div class="contact-item">
            <div class="contact-icon"><Icon name="envelope" /></div>
            <div>
              <h4>Email</h4>
              <p><a href="mailto:mpplwijethunga@gmail.com">mpplwijethunga@gmail.com</a></p>
            </div>
          </div>
          <div class="contact-item">
            <div class="contact-icon"><Icon name="phone" /></div>
            <div>
              <h4>Phone</h4>
              <p><a href="tel:+94768681539">+94 768681539</a></p>
            </div>
          </div>
        </div>
        <h3>Follow Me</h3>
        <div class="social-links">
          {
            socials.map((social) => (
              <a
                href={social.url}
                class="social-link"
                target="_blank"
                rel="noopener"
                aria-label={social.label}
              >
                <Icon name={social.icon} set="brands" />
              </a>
            ))
          }
        </div>
      </div>
      <form action="https://formspree.io/f/mnndprno" method="POST">
        <div class="form-group">
          <label for="contact-name" class="sr-only">Your Name</label>
          <input
            type="text"
            id="contact-name"
            name="name"
            class="form-control"
            placeholder="Your Name"
            autocomplete="name"
            required
          />
        </div>
        <div class="form-group">
          <label for="contact-email" class="sr-only">Your Email</label>
          <input
            type="email"
            id="contact-email"
            name="email"
            class="form-control"
            placeholder="Your Email"
            autocomplete="email"
            required
          />
        </div>
        <div class="form-group">
          <label for="contact-subject" class="sr-only">Subject</label>
          <input
            type="text"
            id="contact-subject"
            name="subject"
            class="form-control"
            placeholder="Subject"
          />
        </div>
        <div class="form-group">
          <label for="contact-message" class="sr-only">Your Message</label>
          <textarea
            id="contact-message"
            name="message"
            class="form-control"
            placeholder="Your Message"
            required></textarea>
        </div>
        <button type="submit" class="btn">Send Message</button>
      </form>
    </div>
  </div>
</section>

<style>
  .contact-info a {
    color: inherit;
    text-decoration: none;
  }
  .contact-info a:hover {
    color: var(--secondary-color);
  }
</style>
