---
import Icon from './Icon.astro';
import { withBase } from '../utils/url';

const cvUrl = withBase('documents/Lakmal_Wijethunga_CV.pdf');
const year = new Date().getFullYear();
---

<footer>
  <div class="container">
    <div class="footer-content">
      <div class="footer-logo">Lakmal<span>Wijethunga</span></div>
      <p>3D Artist & Digital Creator</p>
      <div class="footer-links">
        <a href="#home">Home</a>
        <a href="#about">About</a>
        <a href="#services">Services</a>
        <a href="#projects">Portfolio</a>
        <a href="#contact">Contact</a>
        <a href={cvUrl} download="Lakmal_Wijethunga_CV.pdf"><Icon name="download" /> CV</a>
      </div>
      <div class="copyright">
        <p>&copy; {year} Lakmal Wijethunga. All Rights Reserved.</p>
      </div>
    </div>
  </div>
</footer>
